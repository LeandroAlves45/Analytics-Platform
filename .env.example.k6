# Base URL da API (backend correr em localhost:3000)
API_URL=http://host.docker.internal:3000

# API key para sustained/peak tests
API_KEY=apk_xyz_your_key

# Lista de API keys para cold-cache (múltiplas keys)
# Cole 10-50 keys comma-separated (pode copiar a mesma key múltiplas vezes em dev)
API_KEYS=apk_key1,apk_key2

# Busca Jwt token já com o código implementado
# Varáveis apenas para teste, só para o dashbord test
TEST_EMAIL=your_email_test
TEST_PASSWORD=your_pass_test