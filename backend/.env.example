# Environment variables
NODE_ENV=development
LOG_LEVEL=info

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
# Em dev com Docker: usar 5433 / 6380 conforme o compose.yml
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=analytics_db
DATABASE_USER=analytics_user
DATABASE_PASSWORD=analyticspass

# Redis
# Porta padrão 6379. Com Docker local usar 6380.
REDIS_URL=redis://localhost:6379/0
METRICS_CACHE_TTL_SECONDS=300

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxx

# JWT (obrigatório)
# JWT_SECRET: mínimo 32 caracteres em produção
JWT_SECRET=dev-secret-min-32-chars-for-local-only!!
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_SECONDS=604800

# Rate limits (requests/min por API key). Enterprise: limite negociado, sem env var.
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_BUSINESS=5000

# Slack (Alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# Não é lido pelo GitHub Actions — configurar em Secrets → Actions → CODECOV_TOKEN
CODECOV_TOKEN=your-codecov-token