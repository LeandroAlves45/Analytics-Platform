{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "noEmit": true,
    "rootDir": ".",
    "isolatedModules": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    ".claude",
    ".cursor",
    ".vscode",
    ".git",
    "build"
  ]
}
