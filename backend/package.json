{
  "name": "analytics-saas-backend",
  "version": "1.0.0",
  "description": "Real-time analytics platform for APIs developers",
  "main": "dist/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:unit": "jest --selectProjects unit",
    "test:unit:watch": "jest --selectProjects unit --watch",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:integration:watch": "jest --selectProjects integration --runInBand --watch",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:unit": "jest --selectProjects unit --coverage",
    "test:coverage:integration": "jest --selectProjects integration --coverage --coverageThreshold={} --runInBand",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infra/frameworks/database/migrate.ts",
    "db:hypertables": "tsx src/infra/frameworks/database/migrate.ts --hypertables-only",
    "db:studio": "drizzle-kit studio",
    "prepare": "cd .. && husky install backend/.husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@slack/webhook": "^7.0.9",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "5.77.6",
    "ci": "^2.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.11.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.2.3",
    "stripe": "^14.0.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0"
  }
}
