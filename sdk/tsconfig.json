{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "moduleResolution": "Node16",
    "types": ["node"],

    // Emite ficheiros .d.ts para que quem instala o SDK tenha tipos Typescript
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Output para pasta dist/
    "outDir": "./dist",
    "rootDir": "./src",

    // Strict mode obrigatório para TS 6.
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests", ".claude", ".cursor", ".vscode", ".git", "build"]
}
